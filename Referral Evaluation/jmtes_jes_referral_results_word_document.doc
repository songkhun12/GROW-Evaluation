\par
\pard\b Table 1 Impact of GROW on Behavioral Referral Outcomes\b0\par
\par
\pard  	 Classroom referrals 	 Classroom severity-weighted frequency 	 Bus referrals 	 Bus severity-weighted frequency\par
\pard  	 (1) 	 (2) 	 (3) 	 (4)\par
\pard Model 	 OW Poisson + covariates 	 OW Poisson + covariates 	 OW Poisson + covariates 	 OW Poisson + covariates\par
\pard JMTES (GROW school) 	 -0.894*** 	 -0.737*** 	 -1.638*** 	 -1.573***\par
\pard  	 (0.196) 	 (0.194) 	 (0.317) 	 (0.324)\par
\pard Incidence rate ratio 	 0.409 	 0.478 	 0.194 	 0.207\par
\pard Percent difference 	 -59.1% 	 -52.2% 	 -80.6% 	 -79.3%\par
\pard JES weighted rate per 170 days 	 0.669 	 1.558 	 0.163 	 0.331\par
\pard JMTES weighted rate per 170 days 	 0.274 	 0.750 	 0.032 	 0.071\par
\pard Student covariates 	 Yes 	 Yes 	 Yes 	 Yes\par
